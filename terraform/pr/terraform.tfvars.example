# DigitalOcean Configuration
do_token = "your-digitalocean-api-token-here"

# Infrastructure Configuration
region = "nyc1"

# Deployment identification
deployment_id = "pr-1-automated-deployment"  # Format: pr-{number}-{branch}

# GitHub Integration
# Note: github_repo is auto-detected from GITHUB_REPOSITORY environment variable
docker_image_tag = "pr-1-automated-deployment"

