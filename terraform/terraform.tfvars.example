# DigitalOcean Configuration
do_token = "your-digitalocean-api-token-here"

# Infrastructure Configuration
region = "nyc1"                         # DigitalOcean region

# Deployment identification (set by GitHub Actions)
deployment_id = "pr-1-automated-deployment"

# DigitalOcean Spaces credentials for state backend
spaces_access_key = "your-do-spaces-access-key"
spaces_secret_key = "your-do-spaces-secret-key"

# GitHub Integration (set by GitHub Actions)
github_repo = "user/repo"
docker_image_tag = "pr-1-automated-deployment"
github_token = "github_token_here"

# Auto-termination Configuration
auto_terminate_minutes = 30

# Domain Configuration (optional)
# domain_name = "your-domain.com"